@page "/Register"
@model RegisterForm.Pages.RegisterModel

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Register</title>
    <link rel="stylesheet" href="~/css/register.css" asp-append-version="true">
  </head>
  <body>
    <main class="auth-shell">
      <section class="register-card" aria-labelledby="form-title">
        <header class="card-header">
          <h1 id="form-title">Register</h1>
          <p>Create your account. It's free and only takes a minute.</p>
        </header>

        <form method="post" id="register-form" novalidate>
          <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

          <div class="name-grid">
            <label>
              <span class="sr-only">First Name</span>
              <input asp-for="Input.FirstName" autocomplete="given-name" placeholder="First Name">
              <span asp-validation-for="Input.FirstName" class="field-validation"></span>
            </label>
            <label>
              <span class="sr-only">Last Name</span>
              <input asp-for="Input.LastName" autocomplete="family-name" placeholder="Last Name">
              <span asp-validation-for="Input.LastName" class="field-validation"></span>
            </label>
          </div>

          <label>
            <span class="sr-only">Email</span>
            <input asp-for="Input.Email" autocomplete="email" placeholder="Email">
            <span asp-validation-for="Input.Email" class="field-validation"></span>
          </label>

          <label>
            <span class="sr-only">Password</span>
            <input asp-for="Input.Password" autocomplete="new-password" placeholder="Password">
            <span asp-validation-for="Input.Password" class="field-validation"></span>
          </label>

          <label>
            <span class="sr-only">Confirm Password</span>
            <input asp-for="Input.ConfirmPassword" autocomplete="new-password" placeholder="Confirm Password">
            <span asp-validation-for="Input.ConfirmPassword" class="field-validation"></span>
          </label>

          <p class="form-status @(Model.IsRegistered ? "success" : "")" id="form-status" aria-live="polite">
            @(Model.IsRegistered ? "Registration data is valid." : "")
          </p>

          <button type="submit">Register Now</button>
        </form>
      </section>
    </main>

    <script src="~/js/register.js" asp-append-version="true"></script>
  </body>
</html>
